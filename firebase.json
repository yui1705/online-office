{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "*.log",
      "**/.*",
      ".git",
      ".git/**",
      ".firebase",
      ".firebase/**",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
